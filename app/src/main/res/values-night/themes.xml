<?xml version="1.0" encoding="utf-8"?>
<!-- File: app/src/main/res/values-night/themes.xml -->
<resources>
    <!-- SplashScreen theme (night) -->
    <style name="Theme.Lionico.Draft.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/transparent</item>
        <item name="windowSplashScreenAnimatedIcon">@null</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.Lionico.Draft.SplashImage</item>
    </style>

    <!-- Theme applied right after splash – shows castle background -->
    <style name="Theme.Lionico.Draft.SplashImage" parent="Theme.Lionico.Draft">
        <item name="android:windowBackground">@drawable/castle_bg</item>
    </style>

    <!-- Main app theme (night) -->
    <style name="Theme.Lionico.Draft" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>
</resources>